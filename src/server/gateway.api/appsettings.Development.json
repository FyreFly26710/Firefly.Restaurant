{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "menu-api-route": {
        "ClusterId": "menu-api-cluster",
        "Match": {
          "Path": "/api/menu/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "menu-api-cluster": {
        "Destinations": {
          "menu-api": {
            "Address": "http://localhost:5188/"
          }
        }
      }
    }
  }
}
